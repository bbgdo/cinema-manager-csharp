<Page x:Class="CinemaManager.Wpf.Pages.HallListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Cinema Halls">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Cinema Halls" FontSize="22" FontWeight="Bold" Margin="0 0 0 16" />

        <ListBox Grid.Row="1"
                 x:Name="HallListBox"
                 SelectionChanged="HallListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4 6">
                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Foreground="Gray">
                            <Run Text="{Binding HallType, Mode=OneWay}" />
                            <Run Text=" · " />
                            <Run Text="{Binding SeatsCount, Mode=OneWay}" />
                            <Run Text=" seats" />
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>